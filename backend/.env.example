# VoxSight backend config.
# Copy to `.env` and fill in tomorrow. Tonight everything stays on `mock`.

# --- Provider selection: `mock` tonight, real provider name tomorrow ---
# STT_PROVIDER:    mock | wispr
# VISION_PROVIDER: mock | qwen
# TTS_PROVIDER:    mock | elevenlabs
STT_PROVIDER=mock
VISION_PROVIDER=mock
TTS_PROVIDER=mock

# --- API keys (leave blank tonight) ---
WISPR_API_KEY=
QWEN_API_KEY=
ELEVENLABS_API_KEY=

# --- Optional tuning ---
# ElevenLabs voice id (default is a generic voice)
ELEVENLABS_VOICE_ID=
# Qwen vision model name
QWEN_MODEL=qwen-vl-max
# CORS: comma-separated origins allowed to hit the backend
ALLOWED_ORIGINS=http://localhost:3000
