# VoxSight backend config. Copy to `.env` and fill in.

# --- Demo mode: off | capture | replay ---
#   off     = normal live pipeline
#   capture = live + save each response to recordings/ (build your replay set)
#   replay  = serve saved responses, ZERO API calls (present/record for free)
DEMO_MODE=off

# --- Provider selection ---
# STT_PROVIDER:    mock | elevenlabs (Scribe) | wispr
# VISION_PROVIDER: mock | gemini | fal | qwen
# TTS_PROVIDER:    mock | elevenlabs
STT_PROVIDER=mock
VISION_PROVIDER=mock
TTS_PROVIDER=mock

# --- API keys ---
ELEVENLABS_API_KEY=
GEMINI_API_KEY=
FAL_KEY=
QWEN_API_KEY=
WISPR_API_KEY=

# --- Optional tuning ---
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL   # "Sarah" — clear, reassuring
ELEVENLABS_MODEL=eleven_flash_v2_5         # lowest latency for real-time
ELEVENLABS_STT_MODEL=scribe_v1
GEMINI_MODEL=gemini-2.5-flash
QWEN_MODEL=qwen-vl-max
# CORS: comma-separated origins allowed to hit the backend
ALLOWED_ORIGINS=http://localhost:3000
